<Window x:Class="PlayLogger.LastPlayedUpdateDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PlayLogger"
             xmlns:cb="clr-namespace:MultiSelectComboBox"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBlock Text="בחר רחבות מקור" HorizontalAlignment="Center" Margin="4"/>
        <StackPanel Orientation="Horizontal">
            <cb:MultiSelectComboBox x:Name="cb" MinWidth="200" Height="40"/>
            <Button Content="עדכן" Click="Close_Click" VerticalAlignment="Center" Padding="10,4" Margin="8"/>
        </StackPanel>
    </StackPanel>
</Window>
